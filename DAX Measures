DAX Measures Used

===== TOTAL REVENUE =====

Total Revenue = SUM(Fact_Financials[Revenue_Amount])

Total Revenue vs Last Month = 
VAR CurrentMonth = [Total Revenue]
VAR LastMonth = 
    CALCULATE(
        [Total Revenue],
        DATEADD('Dim_Date'[Full_Date], -1, MONTH)
    )
RETURN
    IF(
        ISBLANK(LastMonth), 
        BLANK(), 
        CurrentMonth - LastMonth
    )

Total Revenue MoM Label = 
VAR _variance = [Total Revenue vs Last Month]
RETURN
    IF(
        ISBLANK(_variance),
        "vs Previous Month: --",
        VAR Icon = IF(_variance >= 0, "▲", "▼")
        RETURN
        "vs Previous Month: " & Icon & " " & FORMAT(ABS(_variance), "#,##0")
    )

Total Revenue Label Color = 
IF([Total Revenue vs Last Month] = 0, "Black",
    IF([Total Revenue vs Last Month] < 0, "Red", "Green"))

